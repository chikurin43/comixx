# Used by Wrangler (OpenNext preview/dev).
# Do NOT commit `.dev.vars` itself if it contains secrets.
NEXTJS_ENV=development
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# R2 (S3 compatible API)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Optional (E2E)
COMIXX_E2E_EMAIL=
COMIXX_E2E_PASSWORD=
